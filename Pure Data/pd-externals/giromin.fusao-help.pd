#X msg 15 181 reset;
#X text 70 181 reinicia quaternion para identidade (1 0 0 0);
#X msg 15 201 beta 0.1;
#X text 100 201 ganho mais suave (mais lento para convergir);
#X msg 15 221 beta 0.5;
#X text 100 221 ganho mais agressivo (mais rapido\\\, mais ruidoso);
